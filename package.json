{
  "name": "whisper-chat",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "description": "AgentConnect / WhisperChat — two Claude Code agents talking over an in-browser MCP bridge",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "eslint",
    "host:headless": "tsx scripts/headless-host.ts",
    "test:pty": "node scripts/test-pty.mjs",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --import tsx --test tests/unit/whisperState.test.ts tests/unit/whisperBridge.test.ts tests/unit/session.test.ts",
    "test:integration": "node --import tsx --test tests/integration/whisperServer.test.ts tests/integration/sessionRoute.test.ts tests/integration/serverConfig.test.ts",
    "test:e2e": "tsx tests/e2e/whisper-roundtrip.ts",
    "test:e2e:pty": "node tests/e2e/pty-cwd.mjs"
  },
  "dependencies": {
    "@particle-academy/agent-integrations": "^0.19.0",
    "@particle-academy/fancy-term": "^0.3.0",
    "@particle-academy/fancy-term-host": "^0.2.0",
    "@particle-academy/react-fancy": "^4.7.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "next": "16.2.9",
    "node-pty": "^1.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eventsource": "^4.1.0",
    "playwright": "^1.61.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
